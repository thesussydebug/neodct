############################
# Buildroot generated data
############################
buildroot/output/
buildroot/dl/

# Out-of-tree build dirs
build-*/
output-*/

############################
# Python
############################
__pycache__/
*.pyc
*.pyo

############################
# Editors / OS junk
############################
.DS_Store
*.swp
*.swo
*.tmp

############################
# Secrets / keys (never commit)
############################
*.pem
*.key
*.crt
secrets/

############################
# NeoDCT user data (runtime content)
############################
neodct/overlay/User/music/

############################
# NeoDCT large test media (keep repo lean)
############################
neodct/overlay/tests/*.avi
neodct/overlay/tests/*.mp3
neodct/overlay/tests/*.mp4
neodct/overlay/tests/*.mkv
netsurf-neodct/

# Local macOS Docker build helper + its output (not part of the repo)
/build-macos.sh
/output/

# neopix generated test artifacts
neodct/native/neopix/tests/fixtures/
neodct/native/neopix/tests/run_tests
neodct/overlay/root/npx_selftest
neodct/overlay/NeoDCT/lib/libneopix.so

############################
# C rewrite: generated build/test artifacts
############################
# test fixtures are regenerated by `make fixtures` from Pillow
neodct/native/*/tests/fixtures/
neodct/native/*/tests/fixtures_embed.c
# compiled test runners
neodct/native/*/tests/run_*
!neodct/native/*/tests/run_*.c
# built libraries and binaries
neodct/native/*/*.dylib
neodct/native/*/*.so
neodct/overlay/usr/bin/neodct-shell
# font atlases baked at build time by gen_font_atlases.py
neodct/overlay/NeoDCT/System/ui/resources/fonts/atlas_*.bin
# stray nested overlay from an early path bug
neodct/native/overlay/
